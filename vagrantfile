# -*- mode: ruby -*-
# vi: set ft=ruby :

# To enable zsh, please set ENABLE_ZSH env var to "true" before launching vagrant up 
#   + On windows => $env:ENABLE_ZSH="true"
#   + On Linux  => export ENABLE_ZSH="true"

Vagrant.configure("2") do |config|

  # Timeout global
  config.vm.boot_timeout = 600

  # ------------------------------
  # Docker VM
  # ------------------------------
  config.vm.define "docker" do |docker|
    docker.vm.box = "eazytrainingfr/centos7"
    docker.vm.box_version = "1.0"
    docker.vm.network "private_network", ip: "192.168.56.10"
    docker.vm.hostname = "docker"

    docker.vm.provider "virtualbox" do |v|
      v.name = "docker"
      v.memory = 1024
      v.cpus = 2
    end

    docker.vm.provision "shell" do |shell|
      shell.path = "install_docker.sh"
      shell.env = { 'ENABLE_ZSH' => ENV['ENABLE_ZSH'] }
    end
  end

  # ------------------------------
  # Minikube VM
  # ------------------------------
  config.vm.define "minikube" do |minikube|
    minikube.vm.box = "generic/centos7"
    minikube.vm.network "private_network", ip: "192.168.56.15"
    minikube.vm.hostname = "minikube"

    minikube.vm.provider "virtualbox" do |v|
      v.name = "minikube"
      v.memory = 3072
      v.cpus = 2
    end

    minikube.vm.provision "shell",
      path: "install_minikube.sh",
      env: { 'ENABLE_ZSH' => ENV['ENABLE_ZSH'] }
  end

end